#include <WiFi.h>
#include <esp_now.h>
#include "HCSR04.h"

uint8_t macGateway[] = {0xB4, 0xBF, 0xE9, 0x32, 0xDF, 0xE4};

#define ECHO_PIN_VAGA_A1 23
#define TRIG_PIN_VAGA_A1 22
#define LED_VERDE 19
#define LED_VERMELHO 18
#define TOLERANCIA 0.9f

typedef struct{
  bool estadoVaga1;
} DadosVagas;

DadosVagas dados;

HCSR04 sensorVagaA1(ECHO_PIN_VAGA_A1, TRIG_PIN_VAGA_A1);

float alturaSensorChao;

void setup() {
  Serial.begin(115200);
  pinMode(LED_VERDE, OUTPUT);
  pinMode(LED_VERMELHO, OUTPUT);
  setupEspNow();
  calibrarSensor();
  delay(2000);
  Serial.print("Canal do transmissor: ");
  Serial.println(WiFi.channel());
}

void loop() {
  static unsigned long tempoLoop = 0;
  const unsigned long intervaloLoop = 500;

  if (millis() - tempoLoop >= intervaloLoop) {
    tempoLoop = millis();

    float distancia = sensorVagaA1.lerDistancia();
    bool vagaOcupada = (distancia > 0 && distancia < alturaSensorChao * TOLERANCIA);
    digitalWrite(LED_VERDE, vagaOcupada ? LOW : HIGH);
    digitalWrite(LED_VERMELHO, vagaOcupada? HIGH : LOW);

    if (vagaOcupada != dados.estadoVaga1) {
      dados.estadoVaga1 = vagaOcupada;
      enviarDados();
    }
  }
}
